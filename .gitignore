.baseline/

# Python bytecode / caches
__pycache__/
*.pyc
*.pyo

# Generated run artifacts (governed outputs; do not hand-edit)
OUTPUTS/RUNS/

# Case artifacts are local-only (templates are tracked)
CASES/ACTIVE/
CASES/ARCHIVE/

# Quarantine + meta folders are local evidence storage (append-only)
# Exception: provenance genesis is governed and must be tracked.
SYSTEM/META/**
!SYSTEM/META/PROVENANCE/
!SYSTEM/META/PROVENANCE/genesis.v1.json

# Clerk logs (runtime noise)
SYSTEM/LOGS/CLERK/*.log

# SOCIALOPS artifacts (generated; local-only unless explicitly promoted)
SOCIAL/DRAFTS/
SOCIAL/RECEIPTS/
SOCIAL/QUEUE/
SOCIAL/SOURCES/

# Yggdrasil Canon (operational ledger + receipts)
canon/
canon/**
