{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aurenyx.com/squad/schemas/battlebuddy/cra_output.schema.json",
  "title": "BattleBuddy — Claim Readiness Analysis (CRA) Output Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["module", "version", "created_at", "status"],
  "properties": {
    "module": {
      "type": "string",
      "const": "battlebuddy.cra"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Semantic version of the CRA output payload format."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["ok", "refused"]
    },

    "refusal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason_codes", "message"],
      "properties": {
        "reason_codes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "unsafe_content_detected",
              "medical_inference_requested",
              "eligibility_or_outcome_prediction_requested",
              "prohibited_free_text_detected",
              "attachment_or_document_parsing_attempt"
            ]
          }
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "description": "Human-safe refusal message; no PHI."
        }
      }
    },

    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["readiness"],
      "properties": {
        "readiness": {
          "type": "string",
          "enum": [
            "incomplete_common_gaps",
            "procedurally_ready_verification_pending",
            "administrative_barriers_detected",
            "unknown"
          ]
        },
        "notes": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "string",
            "description": "Short, non-medical, non-outcome language."
          }
        }
      }
    },

    "gap_map": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gap", "presence"],
        "properties": {
          "gap": {
            "type": "string",
            "enum": [
              "service_records_missing_or_unknown",
              "current_diagnosis_docs_missing_or_unknown",
              "nexus_opinion_missing_or_unknown",
              "lay_statements_missing_or_unknown",
              "continuity_evidence_missing_or_unknown",
              "prior_decision_missing_or_unknown",
              "appeal_lane_unknown",
              "representation_missing_or_unknown"
            ]
          },
          "presence": {
            "type": "string",
            "enum": ["present", "missing", "unknown"]
          },
          "safe_rationale": {
            "type": "string",
            "description": "Process-only rationale; no medical detail.",
            "minLength": 1
          }
        }
      }
    },

    "procedural_patterns": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "enum": [
          "missing_nexus_is_common_denial_reason",
          "continuity_gaps_can_block_service_connection",
          "service_records_requests_can_take_time",
          "appeal_lane_choice_has_deadlines",
          "representation_can_reduce_process_friction"
        ]
      }
    },

    "next_safe_steps": {
      "type": "array",
      "minItems": 0,
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step"],
        "properties": {
          "step": {
            "type": "string",
            "enum": [
              "request_service_records",
              "obtain_prior_va_decision_letters",
              "seek_accredited_representation",
              "confirm_appeal_lane_and_deadlines",
              "collect_lay_statements",
              "build_one_page_timeline"
            ]
          },
          "notes": {
            "type": "string",
            "description": "Optional non-medical clarifier."
          }
        }
      }
    }
  },

  "allOf": [
    {
      "if": {
        "properties": {"status": {"const": "refused"}}
      },
      "then": {
        "required": ["refusal"],
        "not": {
          "anyOf": [
            {"required": ["summary"]},
            {"required": ["gap_map"]},
            {"required": ["procedural_patterns"]},
            {"required": ["next_safe_steps"]}
          ]
        }
      },
      "else": {
        "required": ["summary", "gap_map", "procedural_patterns", "next_safe_steps"],
        "not": {"required": ["refusal"]}
      }
    }
  ]
}
